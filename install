#!/usr/bin/env bash

cd $(dirname $0)

_backup () {
    [ -L ${1} ] && rm ${1}
    [ -e ${1} ] && echo "  move: [${1}] -> [${1}.BACKUP]"
    [ -e ${1} ] && mv ${1} ${1}.BACKUP
}

_link () {
    real=$1
    name=$(basename $1)
    [ ! ${name:0:1} == . ] && name=.${name}
    link=${HOME}/${name}
    _backup ${link}
    echo "  link [${link}] -> [${real}]"
    ln -s ${real} ${link}
}

_linkall () {
    for pth in $(ls $1); do
        _link $1/$pth
    done
}

_link ${PWD}/bash/.profile
_link ${PWD}/bash/.bashrc
_link ${PWD}/bash/.bash_logout
_linkall ${PWD}/public

[ -d ./bryan ] || git clone https://github.com/bryanhann/bryan.git
${PWD}/bryan/decrypt
_linkall ${PWD}/bryan/private/dotfiles
