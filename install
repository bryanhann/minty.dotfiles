cd $(dirname $0)
[ $1. == --force. ] && unzip ./crypt.zip
[ ! -d ./crypt    ] && unzip ./crypt.zip

main () {
    for pth in ${PWD}/crypt ${PWD}/clear; do
        for real in $(ls $pth); do
            _link ${pth}/${real}
         done
    done
    return
    for name in $(ls $PWD/crypt); do
        echo $name
    done

    for name in $(ls $PWD/crypt/dot.*); do
        echo $name
    done
}
_link () {
    real=${1}
    link=${HOME}/.$(basename ${real})
    back=${link}.backup
    [ -L ${link} ] && rm $link
    [ -e ${link} ] && echo "  copy [${link}] -> [${back}]"
    [ -e ${link} ] && mv ${link} ${back}
    true           && echo "  link [${link}] -> [${real}]"
    true           && ln -s ${real} ${link}
}

main 
exit
_link profile
_link bashrc
_link aws
_link vim
_link ssh
